# =============================================================
# .env.example
# 사용법: 이 파일을 .env로 복사하고, 아래 키들에 본인 값 채우기
#   $ cp .env.example .env
# .env 자체는 절대 커밋 X (.gitignore 등록되어 있음)
# =============================================================


# ---------- DB (SQLite, 로컬 파일) ----------
# 그대로 두면 됨. dev.db 파일이 자동 생성됨.
DATABASE_URL=sqlite+aiosqlite:///./dev.db


# ---------- LLM (필수) ----------
# Gemini = Primary. 일일 무료 quota 다 쓰면 자동으로 Groq fallback.
# 발급: https://aistudio.google.com/apikey  (Google 계정 로그인 → "Create API key")
GEMINI_API_KEY=

# Groq = Fallback. 무료 tier 충분.
# 발급: https://console.groq.com/keys  (회원가입 → API Keys → Create)
GROQ_API_KEY=

# 모델명. 그대로 둬도 동작. 다른 모델 쓰려면 교체.
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile

# LLM 호출 동작 파라미터. 그대로 두면 OK.
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=30.0


# ---------- 알림 (선택) ----------
# Discord 웹훅 URL. 비우면 stdout 로그로 fallback.
# 발급: 디스코드 서버 → 채널 설정 → 연동 → 웹후크 → 새 웹후크 → URL 복사
DISCORD_WEBHOOK_URL=


# ---------- 네이버 데이터랩 / 쇼핑 (선택) ----------
# 데이터랩 = 트렌드 기능 (/api/stats 트렌드, Phase 6).
#   비우면 트렌드 비활성 (다른 기능은 정상 동작).
# 쇼핑 검색 = /api/search (Phase 7).
#   비우면 /api/search 비활성.
#
# 발급: https://developers.naver.com/apps  (네이버 계정 → 애플리케이션 등록)
#   1) 애플리케이션 등록 → 사용 API에 "데이터랩(쇼핑인사이트)" + "검색" 둘 다 추가
#   2) 발급된 Client ID / Secret 아래에 입력
#
# 같은 키를 데이터랩 + 쇼핑 양쪽에 그대로 써도 됨
# (한 애플리케이션이 여러 API 권한 동시 보유 가능).
# 쇼핑 키를 따로 발급받았으면 NAVER_SHOP_* 만 별도 입력.

NAVER_DATALAB_CLIENT_ID=
NAVER_DATALAB_CLIENT_SECRET=

# 비우면 코드가 자동으로 NAVER_DATALAB_* 키 fallback 사용 (main.py 참조).
NAVER_SHOP_CLIENT_ID=
NAVER_SHOP_CLIENT_SECRET=
